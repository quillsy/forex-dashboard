# -----------------------------------------------------------------------------
# Forex Fundamental Dashboard - API-Keys Beispieldatei (.env.example)
# Benenne diese Datei um in '.env' und füge deine Zugangsdaten ein.
# -----------------------------------------------------------------------------

# 1. FRED (US-Makrodaten)
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# 2. Alpha Vantage (Technische Indikatoren SMA 50/200)
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY_HERE

# 3. NewsData.io (Primärnachrichten)
NEWSDATA_API_KEY=YOUR_NEWSDATA_API_KEY_HERE

# 4. NewsAPI.org (Nachrichten-Fallback)
NEWSAPI_KEY=YOUR_NEWSAPI_KEY_HERE

# 5. Benzinga (Wirtschaftskalender)
BENZINGA_API_KEY=YOUR_BENZINGA_API_KEY_HERE

# 6. Finnhub (Analysten-Ratings & Kursziele)
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE

# 7. iTick (Echtzeit-Kurse)
ITICK_API_KEY=YOUR_ITICK_API_KEY_HERE

# 8. FCS API (Historische Langzeitdaten + Korrelation)
FCS_API_KEY=YOUR_FCS_API_KEY_HERE

# 9. StockData.org (News Sentiment)
STOCKDATA_API_KEY=YOUR_STOCKDATA_API_KEY_HERE

# Öffentliche APIs (World Bank, Frankfurter, SNB) benötigen KEINE Keys
# und werden daher hier nicht aufgeführt.

# 10. Tiingo (Commodities and VIX)
TIINGO_API_KEY=YOUR_TIINGO_API_KEY_HERE

# 11. EODHD (Supplementary historical prices and country macro fundamentals)
EODHD_API_KEY=YOUR_EODHD_API_KEY_HERE

# 12. BLS (US labor market detailed time series)
BLS_API_KEY=YOUR_BLS_API_KEY_HERE
