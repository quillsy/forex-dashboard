# -----------------------------------------------------------------------------
# Forex Fundamental Dashboard - API-Keys Beispieldatei (.env.example)
# Benenne diese Datei um in '.env' und füge deine Zugangsdaten ein.
# -----------------------------------------------------------------------------

# 1. FRED (US-Makrodaten)
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# 2. Alpha Vantage (FX-Wechselkurse + Technische Indikatoren)
AV_API_KEY=YOUR_AV_API_KEY_HERE

# 3. NewsData.io (Primärnachrichten)
NEWSDATA_KEY=YOUR_NEWSDATA_KEY_HERE

# 4. NewsAPI.org (Nachrichten-Fallback)
NEWSAPI_KEY=YOUR_NEWSAPI_KEY_HERE

# 5. Benzinga (Wirtschaftskalender)
BENZINGA_KEY=YOUR_BENZINGA_KEY_HERE

# 6. Financial Modeling Prep (FMP) (Analysten-Konsens)
FMP_KEY=YOUR_FMP_KEY_HERE

# 7. FCS API (Historische Daten ab 1995)
FCS_API_KEY=YOUR_FCS_API_KEY_HERE

# 8. StockData.org (News Sentiment)
STOCKDATA_KEY=YOUR_STOCKDATA_KEY_HERE
